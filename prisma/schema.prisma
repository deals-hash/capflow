generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Deal {
  id                String                  @id @default(cuid())
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt
  status            String                  @default("Offer Created")
  requestedAmount   Float
  approvedAmount    Float?
  factorRate        Float?
  termDays          Int?
  brokerContactId   String?
  merchantContactId String?
  brokerShopId      String?
  brokerContact     BrokerContact?          @relation(fields: [brokerContactId], references: [id])
  merchantContact   MerchantContact?        @relation(fields: [merchantContactId], references: [id])
  brokerShop        BrokerShop?             @relation(fields: [brokerShopId], references: [id])
  offers            Offer[]
  bankConnections   BankConnectionRecord[]
  identityRecords   IdentityVerificationRecord[]
  agreements        AgreementRecord[]
  notifications     NotificationLog[]
  underwritingDecisions UnderwritingDecision[]
  emailSubmissions  EmailSubmission[]
}


model Offer {
  id              String          @id @default(cuid())
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  dealId          String
  deal            Deal            @relation(fields: [dealId], references: [id])
  amount          Float
  factorRate      Float
  termDays        Int
  paymentFrequency String
  position        String          @default("1st")
  originationFee  Float           @default(1)
  commissionPct   Float           @default(10)
  status          OfferStatus     @default(PENDING)
  expiresAt       DateTime?
  snapshots       OfferSnapshot[]
}

enum OfferStatus {
  PENDING
  SENT
  ACCEPTED
  DECLINED
  EXPIRED
}

model OfferSnapshot {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  offerId   String
  offer     Offer    @relation(fields: [offerId], references: [id])
  data      Json
}

model BrokerShop {
  id        String          @id @default(cuid())
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  name      String
  phone     String?
  email     String?
  address   String?
  notes     String?
  contacts  BrokerContact[]
  deals     Deal[]
}

model BrokerContact {
  id        String      @id @default(cuid())
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  clerkId   String?     @unique
  name      String
  email     String      @unique
  phone     String?
  company   String?
  role      String?
  isPrimary Boolean     @default(false)
  shopId    String?
  shop      BrokerShop? @relation(fields: [shopId], references: [id])
  deals     Deal[]
}

model MerchantContact {
  id           String   @id @default(cuid())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  clerkId      String?  @unique
  businessName String
  ownerName    String
  email        String   @unique
  phone        String?
  ein          String?
  ownerDob     String?
  ownerSsnLast4 String?
  deals        Deal[]
}

model BankConnectionRecord {
  id               String   @id @default(cuid())
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  dealId           String
  deal             Deal     @relation(fields: [dealId], references: [id])
  plaidAccessToken String?
  plaidItemId      String?
  institutionName  String?
  status           String   @default("PENDING")
  rawData          Json?
}

model IdentityVerificationRecord {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  dealId      String
  deal        Deal     @relation(fields: [dealId], references: [id])
  provider    String   @default("persona")
  inquiryId   String?
  status      String   @default("PENDING")
  completedAt DateTime?
  rawData     Json?
}

model AgreementRecord {
  id           String    @id @default(cuid())
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  dealId       String
  deal         Deal      @relation(fields: [dealId], references: [id])
  provider     String    @default("dropbox_sign")
  signatureRequestId String?
  status       String    @default("PENDING")
  signedAt     DateTime?
  documentUrl  String?
  rawData      Json?
}

model NotificationLog {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  dealId    String?
  deal      Deal?    @relation(fields: [dealId], references: [id])
  channel   String
  recipient String
  subject   String?
  status    String   @default("SENT")
  rawData   Json?
}

model UnderwritingDecision {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  dealId      String
  deal        Deal     @relation(fields: [dealId], references: [id])
  decision    String
  score       Float?
  reasons     Json?
  decidedBy   String?
  notes       String?
}

model EmailSubmission {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  dealId      String?
  deal        Deal?    @relation(fields: [dealId], references: [id])
  messageId   String?
  fromEmail   String
  fromName    String?
  toEmails    String[]
  ccEmails    String[]
  subject     String?
  attachments Json
}
